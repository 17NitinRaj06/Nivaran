rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function isOfficerOrAdmin() {
      return isAuth() && (
        request.auth.token.role == 'officer' ||
        request.auth.token.role == 'admin'
      );
    }

    // Users collection
    match /users/{userId} {
      // Users can read own profile; officers/admins can read any
      allow read: if isOwner(userId) || isOfficerOrAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // Reports collection
    match /reports/{reportId} {
      // Anyone can read reports (public civic data)
      allow read: if true;
      // Authenticated users can create their own reports
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      // Owner can update; officers/admins can update any
      allow update: if isOwner(request.resource.data.userId) || isOfficerOrAdmin();
      allow delete: if false;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuth();
      allow update: if isOwner(resource.data.userId);
      allow delete: if false;
    }
  }
}
